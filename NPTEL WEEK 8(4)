#include<stdio.h>
#include<string.h>

void reverse(char[], int, int);
    int main()
    {
        char str1[20];
        scanf("%s", str1);
int n = strlen(str1);
reverse(str1,0,n-1);
printf("The string after reversing is: %s",str1);
return 0;
}
void reverse(char str[],int start,int end)
{
  char temp;
  if(start>=end){
    return;
}
  temp=str[start];
  str[start]=str[end];
  str[end]=temp;
  reverse(str,start+1,end-1);
}
